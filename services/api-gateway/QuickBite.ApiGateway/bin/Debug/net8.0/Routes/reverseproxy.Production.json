{
  "Cors": {
    "AllowedOrigins": [
      "https://quickbite-frontend-ui8k.onrender.com"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-api": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/Auth/{**catch-all}"
        }
      },
      "auth-api-root": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/Auth"
        }
      },
      "restaurant-api": {
        "ClusterId": "restaurant-cluster",
        "Match": {
          "Path": "/api/Restaurants/{**catch-all}"
        }
      },
      "restaurant-api-root": {
        "ClusterId": "restaurant-cluster",
        "Match": {
          "Path": "/api/Restaurants"
        }
      },
      "menu-categories-api": {
        "ClusterId": "menu-cluster",
        "Match": {
          "Path": "/api/MenuCategories/{**catch-all}"
        }
      },
      "menu-categories-api-root": {
        "ClusterId": "menu-cluster",
        "Match": {
          "Path": "/api/MenuCategories"
        }
      },
      "menu-items-api": {
        "ClusterId": "menu-cluster",
        "Match": {
          "Path": "/api/MenuItems/{**catch-all}"
        }
      },
      "menu-items-api-root": {
        "ClusterId": "menu-cluster",
        "Match": {
          "Path": "/api/MenuItems"
        }
      },
      "cart-api": {
        "ClusterId": "cart-cluster",
        "Match": {
          "Path": "/api/v1/cart/{**catch-all}"
        }
      },
      "cart-api-root": {
        "ClusterId": "cart-cluster",
        "Match": {
          "Path": "/api/v1/cart"
        }
      },
      "cart-api-legacy": {
        "ClusterId": "cart-cluster",
        "Match": {
          "Path": "/api/Cart/{**catch-all}"
        }
      },
      "cart-api-legacy-root": {
        "ClusterId": "cart-cluster",
        "Match": {
          "Path": "/api/Cart"
        }
      },
      "order-api": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        }
      },
      "order-api-root": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/v1/orders"
        }
      },
      "payment-api": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/v1/payments/{**catch-all}"
        }
      },
      "payment-api-root": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/v1/payments"
        }
      },
      "wallet-api": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/v1/wallet/{**catch-all}"
        }
      },
      "wallet-api-root": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/v1/wallet"
        }
      },
      "agent-api": {
        "ClusterId": "agent-cluster",
        "Match": {
          "Path": "/api/v1/agents/{**catch-all}"
        }
      },
      "agent-api-root": {
        "ClusterId": "agent-cluster",
        "Match": {
          "Path": "/api/v1/agents"
        }
      },
      "review-api": {
        "ClusterId": "review-cluster",
        "Match": {
          "Path": "/api/v1/reviews/{**catch-all}"
        }
      },
      "review-api-root": {
        "ClusterId": "review-cluster",
        "Match": {
          "Path": "/api/v1/reviews"
        }
      },
      "notification-api": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        }
      },
      "notification-api-root": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v1/notifications"
        }
      },
      "auth-swagger": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/auth"
          }
        ]
      },
      "restaurant-swagger": {
        "ClusterId": "restaurant-cluster",
        "Match": {
          "Path": "/restaurant/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/restaurant"
          }
        ]
      },
      "menu-swagger": {
        "ClusterId": "menu-cluster",
        "Match": {
          "Path": "/menu/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/menu"
          }
        ]
      },
      "cart-swagger": {
        "ClusterId": "cart-cluster",
        "Match": {
          "Path": "/cart/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/cart"
          }
        ]
      },
      "order-swagger": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/order/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/order"
          }
        ]
      },
      "payment-swagger": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/payment/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/payment"
          }
        ]
      },
      "delivery-agent-swagger": {
        "ClusterId": "agent-cluster",
        "Match": {
          "Path": "/delivery-agent/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/delivery-agent"
          }
        ]
      },
      "agent-swagger": {
        "ClusterId": "agent-cluster",
        "Match": {
          "Path": "/agent/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/agent"
          }
        ]
      },
      "review-swagger": {
        "ClusterId": "review-cluster",
        "Match": {
          "Path": "/review/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/review"
          }
        ]
      },
      "notification-swagger": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/notification/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/notification"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "https://quickbite-backend-auth.onrender.com/"
          }
        }
      },
      "restaurant-cluster": {
        "Destinations": {
          "restaurant-service": {
            "Address": "https://quickbite-backend-restaurant.onrender.com/"
          }
        }
      },
      "menu-cluster": {
        "Destinations": {
          "menu-service": {
            "Address": "https://quickbite-backend-menu.onrender.com/"
          }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "cart-service": {
            "Address": "https://quickbite-backend-cart.onrender.com/"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-service": {
            "Address": "https://quickbite-backend-order.onrender.com/"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-service": {
            "Address": "https://quickbite-backend-payment.onrender.com/"
          }
        }
      },
      "agent-cluster": {
        "Destinations": {
          "agent-service": {
            "Address": "https://quickbite-backend-delivery.onrender.com/"
          }
        }
      },
      "review-cluster": {
        "Destinations": {
          "review-service": {
            "Address": "https://quickbite-backend-review.onrender.com/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-service": {
            "Address": "https://quickbite-backend-notification.onrender.com/"
          }
        }
      }
    }
  }
}
