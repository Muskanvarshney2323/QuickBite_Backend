{
  "JwtSettings": {
    "Key": "ThisIsASecretKeyForJwtTokenGenerationQuickBite!@#$%^&*()1234567890AB",
    "Issuer": "QuickBiteAuthAPI",
    "Audience": "QuickBiteUsers",
    "ExpiryInMinutes": 60
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },

  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {
      "auth-route": {
      "ClusterId": "auth-cluster",
      "Match": { "Path": "/api/Auth/{**catch-all}" }
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": { "Path": "/api/v1/cart/{**catch-all}" }
      },
      "menu-route": {
        "ClusterId": "menu-cluster",
        "Match": { "Path": "/api/v1/menu/{**catch-all}" }
      },
      "orders-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/v1/orders/{**catch-all}" }
      },
      "payments-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/api/v1/payments/{**catch-all}" }
      },
      "restaurants-route": {
        "ClusterId": "restaurant-cluster",
        "Match": { "Path": "/api/v1/restaurants/{**catch-all}" }
      },
      "agents-route": {
        "ClusterId": "delivery-agent-cluster",
        "Match": { "Path": "/api/v1/agents/{**catch-all}" }
      },
      "reviews-route": {
        "ClusterId": "review-cluster",
        "Match": { "Path": "/api/v1/reviews/{**catch-all}" }
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/v1/notifications/{**catch-all}" }
      }
    },

    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-1": { "Address": "http://localhost:5234/" }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "cart-1": { "Address": "http://localhost:5111/" }
        }
      },
      "menu-cluster": {
        "Destinations": {
          "menu-1": { "Address": "http://localhost:5281/" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-1": { "Address": "http://localhost:5113/" }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-1": { "Address": "http://localhost:5114/" }
        }
      },
      "restaurant-cluster": {
        "Destinations": {
          "restaurant-1": { "Address": "http://localhost:5167/" }
        }
      },
      "delivery-agent-cluster": {
        "Destinations": {
          "delivery-agent-1": { "Address": "http://localhost:5115/" }
        }
      },
      "review-cluster": {
        "Destinations": {
          "review-1": { "Address": "http://localhost:5116/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-1": { "Address": "http://localhost:5117/" }
        }
      }
    }
  }
}
